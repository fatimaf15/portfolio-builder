# ==============================================================================
# DEVELOPER PORTFOLIO BUILDER - BACKEND PRODUCTION ENVIRONMENTS
# ==============================================================================

# Server Network Configs
PORT=5000
NODE_ENV=production

# MongoDB Atlas Database URI (Replace with your Atlas connection string)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/portfolio_db?retryWrites=true&w=majority

# JWT Authentication Secret
JWT_SECRET=production_long_cryptographic_random_string_here

# Cross-Origin Allowed Origins (Your production Vercel frontend URL)
FRONTEND_URL=https://your-portfolio-builder.vercel.app

# Optional: Cloudinary Cloud Integrations (For production file uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: GitHub Secure Access Token (To increase proxy limits to 5,000 reqs/hr)
GITHUB_TOKEN=your_github_personal_access_token
